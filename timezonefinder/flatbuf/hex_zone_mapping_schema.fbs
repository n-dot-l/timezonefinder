namespace timezonefinder.flatbuf;

// mapping from H3 hexagon id to a unique zone id
table HexZoneMappingEntry {
  // H3 hexagon ID, uint64
  hex_id:ulong;
  // unique zone ID (ushort) for this hexagon
  zone_id:ushort;
}

table HexZoneMappingCollection {
  entries:[HexZoneMappingEntry];
}

root_type HexZoneMappingCollection;